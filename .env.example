# NyayaAI — Environment Variables Example
# Copy to .env.local and fill in. Never commit .env.local.

# --- GCP / Vertex ---
GOOGLE_CLOUD_PROJECT=nyayai-staging
GOOGLE_CLOUD_LOCATION=asia-south1
VERTEX_AGENT_ENGINE_ID=

# --- Gemini models (2026) ---
GEMINI_PRO_MODEL=gemini-3.1-pro
GEMINI_FLASH_MODEL=gemini-3-flash
GEMINI_FLASH_LITE_MODEL=gemini-3.1-flash-lite

# --- Firebase ---
FIREBASE_PROJECT_ID=nyayai-staging
FIREBASE_APP_ID=
FIREBASE_API_KEY=

# --- Security ---
MODEL_ARMOR_TEMPLATE_ID=nyayai-default
SDP_TEMPLATE_NAME=nyayai-indian-pii

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=https://telemetry.googleapis.com
LOG_LEVEL=info

# --- Local dev ---
USE_FIREBASE_EMULATOR=true
FIRESTORE_EMULATOR_HOST=localhost:8080
